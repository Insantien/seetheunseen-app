// ═══════════════════════════════════════════════════════════
//  See the Unseen — Prisma Schema
//  Database: PostgreSQL (Supabase)
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth Models ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  wishlist          Wishlist[]
  inquiries         Inquiry[]
  brochureDownloads BrochureDownload[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String  // 'google' | 'facebook' | 'email'
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Wishlist ─────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  tourId    String   // Sanity tour _id
  tourSlug  String
  tourTitle String
  tourImage String?  // URL string for quick display
  addedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
}

// ─── Inquiries ────────────────────────────────────────────

model Inquiry {
  id             String        @id @default(cuid())
  referenceNo    String        @unique
  userId         String?       // null = guest inquiry

  // Contact
  fullName       String
  email          String
  phone          String

  // Tour / Destination
  tourId         String?       // Sanity tour _id
  tourTitle      String?
  destinationId  String?       // Sanity destination _id
  destinationTitle String?

  // Travel details
  numAdults      Int           @default(1)
  numChildren    Int           @default(0)
  preferredMonth String?
  preferredDates String?
  message        String?       @db.Text

  // Tracking
  source         String?       // 'tour-page' | 'homepage' | 'quiz' | 'contact'
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?

  // Status & CRM
  status         InquiryStatus @default(RECEIVED)
  hubspotDealId  String?       // HubSpot deal ID after sync
  internalNotes  String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

enum InquiryStatus {
  RECEIVED
  IN_REVIEW
  QUOTE_SENT
  CONFIRMED
  CLOSED
}

// ─── Brochure Downloads (gated PDF downloads) ─────────────

model BrochureDownload {
  id          String   @id @default(cuid())
  userId      String?  // null = not logged in
  email       String
  name        String
  type        String   // 'tour' | 'destination' | 'experience-type'
  contentId   String   // Sanity document _id
  contentSlug String
  downloadedAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ─── Newsletter Subscribers ───────────────────────────────

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
}
